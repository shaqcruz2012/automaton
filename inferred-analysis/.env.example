# ─── Database ────────────────────────────────────────────
# PostgreSQL connection string used by Paperclip server
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# ─── Paperclip ───────────────────────────────────────────
# URL where the Paperclip server is reachable (daemon + notifier connect here)
PAPERCLIP_URL=http://localhost:3100

# ─── Market Data ─────────────────────────────────────────
# Alpha Vantage API key for live market data (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_KEY=

# ─── Trading ─────────────────────────────────────────────
# Alpaca paper/live trading credentials (optional, for execution)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Notifications ───────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram chat ID to receive status reports (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=

# ─── Daemon Tuning ───────────────────────────────────────
# Seconds between research cycles (default: 900 = 15 min)
# DAEMON_INTERVAL=900

# Number of experiments per cycle (default: 5)
# DAEMON_ITERATIONS=5
